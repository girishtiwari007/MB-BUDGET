  </Style>
  <Style ss:ID="HeaderLetter" ss:Parent="Header">
    <Alignment ss:Horizontal="Center" ss:Vertical="Center" ss:WrapText="1"/>
    <Interior ss:Color="#163B5C" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="Total" ss:Parent="Normal">
    <Font ss:FontName="Times New Roman" ss:Size="12" ss:Bold="1"/>
    <Interior ss:Color="#D9EAF7" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="TotalNumber" ss:Parent="Total"><NumberFormat ss:Format="#,##0"/></Style>
  <Style ss:ID="AnomalyNumber" ss:Parent="Number">
    <Interior ss:Color="#FFF2CC" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="AnomalyPercent" ss:Parent="AnomalyNumber"><NumberFormat ss:Format="0"/></Style>
  <Style ss:ID="CriticalNumber" ss:Parent="Number">
    <Interior ss:Color="#F4CCCC" ss:Pattern="Solid"/>
  </Style>
  <Style ss:ID="CriticalPercent" ss:Parent="CriticalNumber"><NumberFormat ss:Format="0"/></Style>
</Styles>
