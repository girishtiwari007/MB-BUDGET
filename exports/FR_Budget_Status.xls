<Styles>
  <Style ss:ID="Default" ss:Name="Normal">
    <Alignment ss:Vertical="Center" ss:WrapText="1"/>
    <Font ss:FontName="Times New Roman" ss:Size="12"/>
  </Style>
  <Style ss:ID="Normal">
    <Alignment ss:Vertical="Center" ss:WrapText="1"/>
    <Borders><Border ss:Position="Bottom" ss:LineStyle="Continuous" ss:Weight="1"/><Border ss:Position="Left" ss:LineStyle="Continuous" ss:Weight="1"/><Border ss:Position="Right" ss:LineStyle="Continuous" ss:Weight="1"/><Border ss:Position="Top" ss:LineStyle="Continuous" ss:Weight="1"/></Borders>
    <Font ss:FontName="Times New Roman" ss:Size="12"/>
  </Style>
  <Style ss:ID="Number" ss:Parent="Normal"><NumberFormat ss:Format="#,##0"/></Style>
  <Style ss:ID="Title">
    <Font ss:FontName="Times New Roman" ss:Size="16" ss:Bold="1" ss:Color="#1F4E79"/>
  </Style>
  <Style ss:ID="Remarks">
    <Font ss:FontName="Times New Roman" ss:Size="12" ss:Bold="1"/>
  </Style>
